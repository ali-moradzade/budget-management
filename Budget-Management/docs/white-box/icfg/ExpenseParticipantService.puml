@startuml
title ExpenseParticipantService ICFG

start

:getExpenseParticipants(userId, expenseId);

:validate user;
:validate expense;

:find participants by expenseId;
:return list;

---

:getAllDebts(userId);

:validate user;
:get all friends;

:for each friend:
  :getDebt(friendId);

:return list;

---

:getDebt(userId, friendId);

:validate user;
:validate friend;

:find unpaid participants;
:sum shareAmount;

:return DebtResponse;

---

:markAsPaid();

:validate user;
:validate participant;
:set paid = true;
:save;

stop
@enduml